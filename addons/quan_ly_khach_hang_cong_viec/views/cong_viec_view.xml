<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cong_viec_tree" model="ir.ui.view">
        <field name="name">cong.viec.tree</field>
        <field name="model">cong_viec</field>
        <field name="arch" type="xml">
            <tree>
                <field name="tieu_de"/>
                <field name="khach_hang_id"/>
                <field name="nhan_vien_thuc_hien_id"/>
                <field name="han_chot"/>
                <field name="trang_thai"/>
            </tree>
        </field>
    </record>

    <record id="view_cong_viec_form" model="ir.ui.view">
        <field name="name">cong.viec.form</field>
        <field name="model">cong_viec</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_tao_noi_dung_ai" string="✨ Nhờ AI viết kịch bản/Email" type="object" class="oe_highlight"/>
                    <field name="trang_thai" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="tieu_de"/>
                            <field name="khach_hang_id"/>
                        </group>
                        <group>
                            <field name="nhan_vien_thuc_hien_id"/>
                            <field name="han_chot"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Mô tả công việc">
                            <field name="mo_ta" placeholder="Nhập yêu cầu để AI dựa vào đó soạn thảo..."/>
                        </page>
                        <page string="🤖 AI Trợ lý">
                            <field name="noi_dung_ai_soan" placeholder="Kết quả AI sinh ra sẽ nằm ở đây..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_cong_viec_kanban" model="ir.ui.view">
        <field name="name">cong.viec.kanban</field>
        <field name="model">cong_viec</field>
        <field name="arch" type="xml">
            <kanban default_group_by="trang_thai" class="o_kanban_small_column">
                <field name="tieu_de"/>
                <field name="khach_hang_id"/>
                <field name="han_chot"/>
                <field name="trang_thai"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="tieu_de"/>
                                </strong>
                                <div class="mt4">
                                    Khách hàng: <field name="khach_hang_id"/>
                                </div>
                                <div class="mt4 text-muted">
                                    Hạn chót: <field name="han_chot"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="action_cong_viec" model="ir.actions.act_window">
        <field name="name">Công việc</field>
        <field name="res_model">cong_viec</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>
</odoo>